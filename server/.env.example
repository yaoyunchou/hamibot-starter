# 本地服务端口
PORT=3000
# AI 服务配置
# 支持 OpenAI / 兼容接口（如 DeepSeek、通义千问、本地 Ollama 等）

# AI API 地址（OpenAI 默认: https://api.openai.com/v1）
# 本地 Ollama: http://localhost:11434/v1
# DeepSeek: https://api.deepseek.com/v1
AI_BASE_URL=https://www.dmxapi.cn/v1

# API Key
AI_API_KEY=your-api-key-here

# 模型名称   
# OpenAI: gpt-4o / gpt-4o-mini
# DeepSeek: deepseek-chat
# Ollama: qwen2.5:7b / llama3.1:8b
AI_MODEL=doubao-seed-2-0-lite-260215

# 视觉模型（用于截图分析，需要支持 vision 的模型，不设置则使用 AI_MODEL）
# 推荐: gpt-4o / gpt-4o-mini / qwen-vl-plus / doubao-vision-pro-32k
AI_VISION_MODEL=doubao-seed-2-0-lite-260215

# OCR 文字不足阈值（低于此数量时触发截图视觉分析，默认 3）
OCR_WEAK_THRESHOLD=3

# 是否使用 response_format: json_object（部分模型不支持，设为 false 关闭）
AI_RESPONSE_FORMAT=false

# 默认任务描述（可被客户端覆盖）
DEFAULT_TASK=浏览当前页面，观察内容并汇报当前状态